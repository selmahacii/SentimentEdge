venv/
ENV/
env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.spyderproject
.spyproject

# Jupyter Notebooks
.ipynb_checkpoints
*.ipynb_checkpoints/

# Data files (too large for git)
data/raw/
data/cleaned/
data/features/
*.db
*.sqlite
*.sqlite3
*.csv
*.json
*.parquet
*.h5
*.hdf5

# Logs
logs/
*.log

# Model cache (HuggingFace, etc.)
.cache/
models/
*.bin
*.pt
*.pth

# Streamlit
.streamlit/secrets.toml

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff
.ruff_cache/

# OS files
.DS_Store
Thumbs.db
*.bak
*.tmp

# Docker
docker-compose.override.yml

# Misc
*.pem
*.key
secrets/

# Keep directory structure
!data/raw/reddit/.gitkeep
!data/raw/prices/.gitkeep
!data/raw/trends/.gitkeep
!data/cleaned/.gitkeep
!data/features/.gitkeep
